from flask import Flask, jsonify, request, render_template
import logging
from datetime import datetime,timedelta
from .database import Database
from .sensor import TemperatureSensor
from .data_processor import DataProcessor
from .predictor import TemperaturePredictor


# 配置日志
logging.basicConfig(
    filename='logs/web_server.log',
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)

app = Flask(__name__, 
            template_folder='../templates',
            static_folder='../static')
db = Database()
sensor = TemperatureSensor()
processor = DataProcessor()
predictor = TemperaturePredictor()

@app.route('/')
def index():
    """渲染主页"""
    return render_template('index.html')


@app.route('/api/temperature/current', methods=['GET'])
def get_current_temperature():
    """获取当前温度"""
    temp = sensor.get_temperature()
    if temp is not None:
        return jsonify({
            'success': True,
            'temperature': temp,
            'unit': 'celsius',
            'timestamp': datetime.now().isoformat()
        })
    else:
        return jsonify({
            'success': False,
            'error': 'Failed to read temperature'
        }), 500

#获取历史温度数据
@app.route('/api/temperature/history', methods=['GET'])
def get_temperature_history():
    """获取历史温度数据"""
    # 获取查询参数
    start_time = request.args.get('start')
    end_time = request.args.get('end')
    limit = request.args.get('limit', default=100, type=int)
    
    # 查询数据
    data = db.get_temperature_data(start_time, end_time, limit)
    
    # 格式化返回结果
    result = [{
        'timestamp': row[0],
        'temperature': row[1]
    } for row in data]
    
    return jsonify({
        'success': True,
        'data': result,
        'count': len(result)
    })


# 创建数据处理器实例
processor = DataProcessor()

@app.route('/api/temperature/stats', methods=['GET'])
def get_temperature_stats():
    """获取温度统计信息"""
    hours = request.args.get('hours', default=24, type=int)
    
    # 获取数据
    data = processor.get_recent_data(hours=hours)
    
    # 如果没有数据
    if not data:
        return jsonify({
            'success': False,
            'error': 'No data available'
        }), 404
        
    # 计算统计信息
    stats = processor.calculate_statistics(data)
    
    # 检测异常值
    outliers = processor.detect_outliers(data)
    outlier_count = sum(1 for _, _, is_outlier in outliers if is_outlier)
    
    # 构建响应
    response = {
        'success': True,
        'period': f'Last {hours} hours',
        'stats': stats,
        'outlier_count': outlier_count
    }
    
    return jsonify(response)



@app.route('/api/temperature/chart-data', methods=['GET'])
def get_chart_data():
    """获取图表数据"""
    hours = request.args.get('hours', default=12, type=int)
    
    # 获取数据
    data = processor.get_recent_data(hours=hours)
    
    # 如果没有数据
    if not data:
        return jsonify({
            'success': False,
            'error': 'No data available'
        }), 404
        
    # 平滑数据
    smoothed_data = processor.smooth_data(data, window_size=3)
    
    # 构建响应
    result = [{
        'timestamp': timestamp,
        'temperature': temp
    } for timestamp, temp in smoothed_data]
    
    return jsonify({
        'success': True,
        'data': result,
        'count': len(result)
    })


@app.route('/api/temperature/predict', methods=['GET'])
def predict_temperature():
    """预测未来温度"""
    hours_ahead = request.args.get('hours', default=3, type=int)
    
    # 获取最近24小时的数据
    data = db.get_temperature_data(
        start_time=(datetime.now() - timedelta(hours=24)).isoformat(),
        end_time=datetime.now().isoformat(),
        limit=100
    )
    
    # 检查数据是否足够
    if len(data) < 24:
        return jsonify({
            'success': False,
            'error': 'Insufficient data for prediction'
        }), 400
    
    # 进行预测
    predictions = predictor.predict_next_hours(data, hours_ahead=hours_ahead)
    
    if not predictions:
        return jsonify({
            'success': False,
            'error': 'Prediction failed'
        }), 500
    
    # 构建响应
    result = [{
        'timestamp': timestamp,
        'predicted_temperature': temp
    } for timestamp, temp in predictions]
    
    return jsonify({
        'success': True,
        'predictions': result,
        'hours_ahead': hours_ahead,
        'model_type': 'tflite' if predictor.interpreter else 'fallback'
    })

@app.route('/api/model/status', methods=['GET'])
def model_status():
    """获取模型状态"""
    status = {
        'tensorflow_available': 'TF_AVAILABLE' in globals() and TF_AVAILABLE,
        'tflite_available': predictor.interpreter is not None,
        'model_loaded': predictor.model is not None or predictor.interpreter is not None,
        'fallback_active': predictor.model is None and predictor.interpreter is None
    }
    
    return jsonify({
        'success': True,
        'status': status
    })

@app.route('/api/model/evaluate', methods=['GET'])
def evaluate_model():
    """评估预测模型性能"""
    test_size = request.args.get('test_size', default=48, type=int)
    
    # 评估模型
    evaluation = predictor.evaluate_model(test_size=test_size)
    
    # 如果评估失败
    if 'error' in evaluation:
        return jsonify({
            'success': False,
            'error': evaluation['error']
        }), 400
        
    # 构建响应
    return jsonify({
        'success': True,
        'evaluation': evaluation
    })

@app.route('/api/config', methods=['GET'])
def get_config():
    """获取系统配置"""
    configs = {
        'sampling_interval': db.get_config('sampling_interval', '600'),
        'alert_threshold': db.get_config('alert_threshold', '35.0')
    }
    
    return jsonify({
        'success': True,
        'config': configs
    })

@app.route('/api/config', methods=['POST'])
def update_config():
    """更新系统配置"""
    data = request.json
    if not data:
        return jsonify({
            'success': False,
            'error': 'No data provided'
        }), 400
    
    # 更新配置
    for key, value in data.items():
        db.set_config(key, str(value))
    
    return jsonify({
        'success': True,
        'message': 'Configuration updated'
    })
